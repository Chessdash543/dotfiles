#!/bin/bash
set -e

DOTFILES="${DOTFILES:-$HOME/dotfiles}"
CONFIG="$DOTFILES/dotfiles.conf"

[ -f "$CONFIG" ] && source "$CONFIG"

cd "$DOTFILES"

echo "=== Restow dotfiles ==="

for app in "${CONFIG_APPS[@]}"; do
  if [ -d "$app" ]; then
    stow -R "$app" 2>/dev/null && echo "  stow $app OK" || echo "  stow $app FAIL"
  fi
done

if [ -d home ]; then
  stow -R home 2>/dev/null && echo "  stow home OK" || echo "  stow home FAIL"
fi

if [ -d config ]; then
  stow -R config 2>/dev/null && echo "  stow config OK" || echo "  stow config FAIL"
fi

# ETC files
for entry in "${ETC_FILES[@]}"; do
  src="${entry#*=}"
  dst="${entry%=*}"
  if [ -f "$DOTFILES/$src" ]; then
    sudo ln -sf "$DOTFILES/$src" "$dst"
    echo "  sudo symlink $dst OK"
  fi
done

echo "=== Pronto ==="
