{
  "layer": "top",
  "position": "top",
  "spacing": 8,
  "margin": "8 8 0 8",
  "height": 40,

  "modules-left": [
    "custom/launcher",
    "hyprland/workspaces"
  ],

  "modules-center": [
    "clock"
  ],

  "modules-right": [
    "tray",
    "custom/system-block"
  ],

  "custom/launcher": {
    "format": "",
    "on-click": "rofi -show drun",
    "tooltip": false
  },

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "disable-click": false,
    "format": "{icon}",
    "format-icons": {
      "active": "●",
      "default": "●",
      "empty": "○"
    },
    "persistent-workspaces": {
      "*": 6
    }
  },

  "clock": {
    "format": "{:%H:%M}",
    "tooltip-format": "<big>{:%A, %d %B %Y}</big>\n<tt>{calendar}</tt>",
    "on-click": "gsimplecal",
    "calendar": {
      "mode": "month",
      "weeks-pos": "right"
    }
  },

  "tray": {
    "spacing": 8
  },

  "custom/system-block": {
    "exec": "$HOME/.config/waybar/scripts/system-block.sh",
    "return-type": "json",
    "interval": 5,
    "on-click": "$HOME/.config/waybar/scripts/system-menu.sh",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%",
    "tooltip": false
  }
}
