    "on-scroll-down": "pamixer -d 5",
    "scroll-step": 5,
    "format-icons": {
      "headphone": "´Çą",
      "hands-free": "´Çą",
      "headset": "´Çą",
      "phone": "´éĽ",
      "portable": "´éĽ",
      "car": "´ć╣",
      "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
    },
    "tooltip": true
  },

  "custom/system-block": {
    "exec": "$HOME/.config/waybar/scripts/system-block.sh",
    "return-type": "json",
    "interval": 5,
    "on-click": "wlogout",
    "on-click-right": "kitty -e nmtui",
    "tooltip": false
  },

  "custom/usrctl": {
    "format": "´äĹ",
    "on-click": "~/.config/eww/scripts/usrctl.sh",
    "tooltip": false
  },

  "custom/musicctl": {
    "format": "´Çą",
    "on-click": "~/.config/eww/scripts/musicctl.sh",
    "tooltip": false
  },

  "custom/swaync": {
    "format" : "{icon}",
    "format-icons": {
      "notification": "´â│<span foreground='red'><small><sup>ÔČĄ</sup></small></span>",
      "none": "´â│",
      "dnd-notification": "´çÂ<span foreground='red'><small><sup>ÔČĄ</sup></small></span>",
      "dnd-none": "´çÂ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "sleep 0.1 && swaync-client -t -sw",
    "escape": true,
    "tooltip": false
  }
}
