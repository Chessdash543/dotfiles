{
  "layer": "top",
  "position": "top",
  "spacing": 8,
  "margin": "8 8 0 8",
  "height": 40,

  "modules-left": [
    "custom/launcher",
    "hyprland/workspaces",
    "custom/hostname",
    "custom/musicctl"
  ],


  "modules-center": [
    "clock"
  ],

  "modules-right": [
    "tray",
    "custom/swaync",
    "pulseaudio",
    "custom/system-block",
    "custom/usrctl"
  ],

  "custom/launcher": {
    "format": "´îâ",
    "on-click": "~/.config/eww/scripts/menuctl.sh",
    "tooltip": false
  },

  "custom/hostname": {
    "format": "´Çç {}",
    "exec": "hostname",
    "interval": 86400,
    "tooltip": false
  },

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "disable-click": false,
    "format": "{icon}",
    "format-icons": {
      "active": "ÔŚĆ",
      "default": "ÔŚĆ",
      "empty": "ÔŚő"
    },
    "persistent-workspaces": {
      "*": 10
    }
  },

  "clock": {
    "format": "{:%H:%M}",
    "on-click": "~/.config/eww/scripts/calendar.sh",
  },

  "tray": {
    "spacing": 8
  },

  "custom/system-info": {
    "exec": "$HOME/.config/waybar/scripts/system-info.sh",
    "return-type": "json",
    "interval": 10,
    "tooltip": false
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "´Üę",
    "on-click": "pamixer -t",
